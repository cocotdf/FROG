{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:frog:expression:schema:frog.front-panel-package:0.1",
  "title": "FROG Front Panel Package",
  "description": "Specialized schema for .wfrog front-panel packages.",
  "allOf": [
    {
      "$ref": "frog.widget-package.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "const": "front_panel_package"
        },
        "front_panels": {
          "type": "array",
          "minItems": 1
        }
      },
      "required": [
        "kind",
        "front_panels"
      ]
    }
  ]
}
