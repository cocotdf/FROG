{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.github.io/frog/schema/ir/frog.execution-ir.schema.json",
  "title": "FROG Execution IR Document",
  "description": "Canonical JSON schema for the FROG Execution IR Document (base v0.1).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ir_version",
    "kind",
    "document_id",
    "unit"
  ],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "0.1",
      "description": "Execution IR version family."
    },
    "kind": {
      "type": "string",
      "const": "execution_ir",
      "description": "Top-level payload classification."
    },
    "document_id": {
      "$ref": "#/$defs/identifier"
    },
    "unit": {
      "$ref": "#/$defs/executionUnit"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/#-]+$"
    },

    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },

    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "typeRef": {
      "description": "Resolved type reference or equivalent normalized type expression.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },

    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "source_node",
            "source_edge",
            "source_region",
            "source_interface_entry",
            "source_widget",
            "source_structure",
            "source_port",
            "source_other"
          ]
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "note": {
          "type": "string"
        }
      }
    },

    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources"
      ],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "multi_contributor",
            "derived_support"
          ]
        }
      }
    },

    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "port_id"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "port_id": {
          "$ref": "#/$defs/identifier"
        }
      }
    },

    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "direction",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "direction": {
          "type": "string",
          "enum": [
            "input",
            "output",
            "bidirectional"
          ]
        },
        "type": {
          "$ref": "#/$defs/typeRef"
        },
        "role": {
          "type": "string",
          "description": "Optional normalized port role classification."
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "baseObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "family",
        "role",
        "ports",
        "attribution"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "family": {
          "type": "string",
          "enum": [
            "primitive",
            "structure",
            "subfrog",
            "boundary",
            "widget_participation",
            "ui_primitive",
            "memory",
            "support"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "support"
          ]
        },
        "kind": {
          "type": "string",
          "description": "Normalized object-specific kind."
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "attribution": {
          "$ref": "#/$defs/attribution"
        },
        "correspondence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "primitiveObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "primitive"
            },
            "role": {
              "const": "primary"
            },
            "primitive_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "primitive_id"
          ]
        }
      ]
    },

    "structureObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "structure"
            },
            "role": {
              "const": "primary"
            },
            "structure_family": {
              "type": "string",
              "enum": [
                "case",
                "for_loop",
                "while_loop"
              ]
            },
            "region_ids": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/identifier"
              }
            }
          },
          "required": [
            "structure_family",
            "region_ids"
          ]
        }
      ]
    },

    "subfrogObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "subfrog"
            },
            "role": {
              "const": "primary"
            },
            "target": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "target"
          ]
        }
      ]
    },

    "boundaryObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "boundary"
            },
            "role": {
              "const": "primary"
            },
            "boundary_kind": {
              "type": "string",
              "enum": [
                "interface_input",
                "interface_output"
              ]
            }
          },
          "required": [
            "boundary_kind"
          ]
        }
      ]
    },

    "widgetParticipationObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "widget_participation"
            },
            "role": {
              "const": "primary"
            },
            "participation_kind": {
              "type": "string",
              "enum": [
                "widget_value",
                "widget_reference"
              ]
            },
            "widget_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "participation_kind",
            "widget_ref"
          ]
        }
      ]
    },

    "uiPrimitiveObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "ui_primitive"
            },
            "role": {
              "const": "primary"
            },
            "primitive_id": {
              "type": "string",
              "enum": [
                "frog.ui.property_read",
                "frog.ui.property_write",
                "frog.ui.method_invoke"
              ]
            }
          },
          "required": [
            "primitive_id"
          ]
        }
      ]
    },

    "memoryObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "memory"
            },
            "role": {
              "const": "primary"
            },
            "memory_kind": {
              "type": "string",
              "enum": [
                "frog.core.delay",
                "other_explicit_memory"
              ]
            },
            "initial": {}
          },
          "required": [
            "memory_kind"
          ]
        }
      ]
    },

    "supportObject": {
      "allOf": [
        {
          "$ref": "#/$defs/baseObject"
        },
        {
          "properties": {
            "family": {
              "const": "support"
            },
            "role": {
              "const": "support"
            },
            "support_kind": {
              "type": "string",
              "enum": [
                "region_record",
                "structure_boundary_terminal",
                "structure_terminal",
                "port_descriptor",
                "source_map_record",
                "classification_record",
                "other_support"
              ]
            }
          },
          "required": [
            "support_kind"
          ]
        }
      ]
    },

    "object": {
      "oneOf": [
        {
          "$ref": "#/$defs/primitiveObject"
        },
        {
          "$ref": "#/$defs/structureObject"
        },
        {
          "$ref": "#/$defs/subfrogObject"
        },
        {
          "$ref": "#/$defs/boundaryObject"
        },
        {
          "$ref": "#/$defs/widgetParticipationObject"
        },
        {
          "$ref": "#/$defs/uiPrimitiveObject"
        },
        {
          "$ref": "#/$defs/memoryObject"
        },
        {
          "$ref": "#/$defs/supportObject"
        }
      ]
    },

    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "destination"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "source": {
          "$ref": "#/$defs/endpoint"
        },
        "destination": {
          "$ref": "#/$defs/endpoint"
        },
        "attribution": {
          "$ref": "#/$defs/attribution"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner_object_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "owner_object_id": {
          "$ref": "#/$defs/identifier"
        },
        "member_object_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "member_connection_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "attribution": {
          "$ref": "#/$defs/attribution"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "sourceMapRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ir_id",
        "sources"
      ],
      "properties": {
        "ir_id": {
          "$ref": "#/$defs/identifier"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    },

    "correspondenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "type": "string",
          "enum": [
            "direct_primary",
            "support_derivation",
            "declaration_reference",
            "intentional_non_primary",
            "true_non_participation"
          ]
        },
        "source_ref": {
          "$ref": "#/$defs/sourceRef"
        },
        "ir_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "executionUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "objects",
        "connections",
        "regions",
        "source_map",
        "correspondence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/object"
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connection"
          }
        },
        "regions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/region"
          }
        },
        "source_map": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceMapRecord"
          }
        },
        "correspondence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/correspondenceRecord"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
