{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.schema.json",
  "title": "FROG Execution IR Document Schema",
  "description": "Canonical JSON schema for the FROG open Execution IR Document in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "document_id",
    "unit"
  ],
  "properties": {
    "schema_family": {
      "type": "string",
      "const": "frog.execution_ir"
    },
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "document_id": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
    },
    "metadata": {
      "$ref": "#/$defs/document_metadata"
    },
    "unit": {
      "$ref": "#/$defs/execution_unit"
    }
  },
  "$defs": {
    "document_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "producer_version": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "unit_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "program_name": {
          "type": "string",
          "minLength": 1
        },
        "profile_set": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "execution_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "objects",
        "connections",
        "regions",
        "source_map",
        "correspondence"
      ],
      "properties": {
        "id": {
          "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
        },
        "metadata": {
          "$ref": "#/$defs/unit_metadata"
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "frog.execution-ir.object.schema.json"
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "frog.execution-ir.connection.schema.json"
          }
        },
        "regions": {
          "type": "array",
          "items": {
            "$ref": "frog.execution-ir.region.schema.json"
          }
        },
        "source_map": {
          "type": "array",
          "items": {
            "$ref": "frog.execution-ir.source-map.schema.json"
          }
        },
        "correspondence": {
          "type": "array",
          "items": {
            "$ref": "frog.execution-ir.correspondence.schema.json"
          }
        }
      }
    }
  }
}
