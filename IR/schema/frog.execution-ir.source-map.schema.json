{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.source-map.schema.json",
  "title": "FROG Execution IR Source Map Record Schema",
  "description": "Component schema for canonical Execution IR source_map records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_kind",
    "source_ref",
    "target_kind",
    "target_refs"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id_string"
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "diagram_node",
        "diagram_edge",
        "interface_port",
        "widget_instance",
        "widget_member",
        "structure",
        "structure_terminal",
        "state_construct",
        "other"
      ]
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "object",
        "connection",
        "region",
        "support_object",
        "none"
      ]
    },
    "target_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id_string"
      }
    },
    "relation": {
      "type": "string",
      "enum": [
        "direct_primary",
        "support_only",
        "multi_target",
        "non_primary"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
