{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.connection.schema.json",
  "title": "FROG Execution IR Connection Record Schema",
  "description": "Component schema for canonical Execution IR connection records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "from",
    "to"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id_string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "dataflow",
        "public_interface_boundary",
        "structure_boundary",
        "state_participation",
        "ui_sequence"
      ]
    },
    "from": {
      "$ref": "#/$defs/endpoint_ref"
    },
    "to": {
      "$ref": "#/$defs/endpoint_ref"
    },
    "attribution": {
      "$ref": "#/$defs/inline_attribution"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/typed_value"
      }
    }
  },
  "$defs": {
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "typed_value": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typed_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typed_value"
          }
        }
      ]
    },
    "endpoint_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "port_id"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/id_string"
        },
        "port_id": {
          "$ref": "#/$defs/id_string"
        }
      }
    },
    "inline_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "multi_contributor",
            "support"
          ]
        }
      }
    }
  }
}
