{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.connection.schema.json",
  "title": "FROG Execution IR Connection Record Schema",
  "description": "Component schema for canonical Execution IR connection records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "from",
    "to"
  ],
  "properties": {
    "id": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "dataflow",
        "public_interface_boundary",
        "structure_boundary",
        "state_participation",
        "ui_sequence"
      ]
    },
    "from": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/endpoint_ref"
    },
    "to": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/endpoint_ref"
    },
    "attribution": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/inline_attribution"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/typed_value"
      }
    }
  }
}
