{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.common.schema.json",
  "title": "FROG Execution IR Common Schema Definitions",
  "description": "Shared schema definitions for the FROG Execution IR schema family in base v0.1.",
  "$defs": {
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "typed_value": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typed_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typed_value"
          }
        }
      ]
    },
    "inline_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "multi_contributor",
            "support"
          ]
        }
      }
    },
    "endpoint_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "port_id"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/id_string"
        },
        "port_id": {
          "$ref": "#/$defs/id_string"
        }
      }
    },
    "member_address_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "property",
            "method",
            "event",
            "part"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "member_address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "widget_ref",
        "path"
      ],
      "properties": {
        "widget_ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/member_address_segment"
          }
        }
      }
    },
    "ui_operation_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_family",
        "widget_ref"
      ],
      "properties": {
        "operation_family": {
          "type": "string",
          "enum": [
            "property_read",
            "property_write",
            "method_invoke"
          ]
        },
        "widget_ref": {
          "type": "string",
          "minLength": 1
        },
        "member_address": {
          "$ref": "#/$defs/member_address"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "operation_family": {
                "enum": [
                  "property_read",
                  "property_write",
                  "method_invoke"
                ]
              }
            },
            "required": [
              "operation_family"
            ]
          },
          "then": {
            "required": [
              "member_address"
            ]
          }
        }
      ]
    },
    "state_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_family"
      ],
      "properties": {
        "state_family": {
          "type": "string",
          "enum": [
            "explicit_local_memory",
            "delay",
            "register",
            "other"
          ]
        },
        "has_initialization": {
          "type": "boolean"
        },
        "initialization_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "port_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "direction",
        "role"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id_string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": [
            "in",
            "out",
            "inout"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "data",
            "selector",
            "condition",
            "iteration",
            "index",
            "state_read",
            "state_write",
            "ui_in",
            "ui_out",
            "boundary",
            "other"
          ]
        },
        "type_ref": {
          "type": "string",
          "minLength": 1
        },
        "boundary_kind": {
          "type": "string",
          "enum": [
            "none",
            "public_interface",
            "structure_boundary",
            "state_boundary",
            "ui_sequence"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typed_value"
          }
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_or_support": {
          "type": "string",
          "enum": [
            "primary",
            "support"
          ]
        },
        "library_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "structure_family": {
          "type": "string",
          "enum": [
            "case",
            "for_loop",
            "while_loop"
          ]
        }
      }
    }
  }
}
