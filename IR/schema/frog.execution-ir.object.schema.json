{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.object.schema.json",
  "title": "FROG Execution IR Object Record Schema",
  "description": "Component schema for canonical Execution IR object records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "family",
    "kind",
    "ports"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id_string"
    },
    "family": {
      "type": "string",
      "enum": [
        "primitive",
        "subfrog_invocation",
        "structure",
        "interface_input",
        "interface_output",
        "widget_value",
        "widget_reference",
        "ui_property_read",
        "ui_property_write",
        "ui_method_invoke",
        "state",
        "support"
      ]
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "$ref": "#/$defs/classification"
    },
    "ports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/port_record"
      }
    },
    "regions_owned": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id_string"
      }
    },
    "member_address": {
      "$ref": "#/$defs/member_address"
    },
    "ui_operation": {
      "$ref": "#/$defs/ui_operation_descriptor"
    },
    "state": {
      "$ref": "#/$defs/state_descriptor"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/typed_value"
      }
    },
    "attribution": {
      "$ref": "#/$defs/inline_attribution"
    },
    "correspondence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id_string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "family": {
            "const": "structure"
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "required": [
              "structure_family"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "family": {
            "enum": [
              "ui_property_read",
              "ui_property_write",
              "ui_method_invoke"
            ]
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "required": [
          "ui_operation"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "family": {
            "const": "state"
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "required": [
          "state"
        ]
      }
    }
  ],
  "$defs": {
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "typed_value": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typed_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typed_value"
          }
        }
      ]
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_or_support": {
          "type": "string",
          "enum": [
            "primary",
            "support"
          ]
        },
        "library_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "structure_family": {
          "type": "string",
          "enum": [
            "case",
            "for_loop",
            "while_loop"
          ]
        }
      }
    },
    "port_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "direction",
        "role"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id_string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": [
            "in",
            "out",
            "inout"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "data",
            "selector",
            "condition",
            "iteration",
            "index",
            "state_read",
            "state_write",
            "ui_in",
            "ui_out",
            "boundary",
            "other"
          ]
        },
        "type_ref": {
          "type": "string",
          "minLength": 1
        },
        "boundary_kind": {
          "type": "string",
          "enum": [
            "none",
            "public_interface",
            "structure_boundary",
            "state_boundary",
            "ui_sequence"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typed_value"
          }
        }
      }
    },
    "member_address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "widget_ref",
        "path"
      ],
      "properties": {
        "widget_ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/member_address_segment"
          }
        }
      }
    },
    "member_address_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "property",
            "method",
            "event",
            "part"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ui_operation_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_family",
        "widget_ref"
      ],
      "properties": {
        "operation_family": {
          "type": "string",
          "enum": [
            "property_read",
            "property_write",
            "method_invoke"
          ]
        },
        "widget_ref": {
          "type": "string",
          "minLength": 1
        },
        "member_address": {
          "$ref": "#/$defs/member_address"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "operation_family": {
                "enum": [
                  "property_read",
                  "property_write",
                  "method_invoke"
                ]
              }
            },
            "required": [
              "operation_family"
            ]
          },
          "then": {
            "required": [
              "member_address"
            ]
          }
        }
      ]
    },
    "state_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_family"
      ],
      "properties": {
        "state_family": {
          "type": "string",
          "enum": [
            "explicit_local_memory",
            "delay",
            "register",
            "other"
          ]
        },
        "has_initialization": {
          "type": "boolean"
        },
        "initialization_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inline_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "multi_contributor",
            "support"
          ]
        }
      }
    }
  }
}
