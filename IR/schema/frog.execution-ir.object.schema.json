{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.object.schema.json",
  "title": "FROG Execution IR Object Record Schema",
  "description": "Component schema for canonical Execution IR object records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "family",
    "kind",
    "ports"
  ],
  "properties": {
    "id": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
    },
    "family": {
      "type": "string",
      "enum": [
        "primitive",
        "subfrog_invocation",
        "structure",
        "interface_input",
        "interface_output",
        "widget_value",
        "widget_reference",
        "ui_property_read",
        "ui_property_write",
        "ui_method_invoke",
        "state",
        "support"
      ]
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/classification"
    },
    "ports": {
      "type": "array",
      "items": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/port_record"
      }
    },
    "regions_owned": {
      "type": "array",
      "items": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
      }
    },
    "member_address": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/member_address"
    },
    "ui_operation": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/ui_operation_descriptor"
    },
    "state": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/state_descriptor"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/typed_value"
      }
    },
    "attribution": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/inline_attribution"
    },
    "correspondence_refs": {
      "type": "array",
      "items": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "family": {
            "const": "structure"
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "properties": {
          "classification": {
            "required": [
              "structure_family"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "family": {
            "enum": [
              "ui_property_read",
              "ui_property_write",
              "ui_method_invoke"
            ]
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "required": [
          "ui_operation"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "family": {
            "const": "state"
          }
        },
        "required": [
          "family"
        ]
      },
      "then": {
        "required": [
          "state"
        ]
      }
    }
  ]
}
