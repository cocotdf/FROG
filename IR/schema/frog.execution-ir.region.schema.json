{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.region.schema.json",
  "title": "FROG Execution IR Region Record Schema",
  "description": "Component schema for canonical Execution IR region records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "owner_object_id",
    "role"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id_string"
    },
    "owner_object_id": {
      "$ref": "#/$defs/id_string"
    },
    "role": {
      "type": "string",
      "enum": [
        "body",
        "case_arm",
        "condition",
        "init",
        "update",
        "other"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "member_object_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id_string"
      }
    },
    "attribution": {
      "$ref": "#/$defs/inline_attribution"
    }
  },
  "$defs": {
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "inline_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "multi_contributor",
            "support"
          ]
        }
      }
    }
  }
}
