{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graiphic.io/frog/ir/schema/frog.execution-ir.region.schema.json",
  "title": "FROG Execution IR Region Record Schema",
  "description": "Component schema for canonical Execution IR region records in base v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "owner_object_id",
    "role"
  ],
  "properties": {
    "id": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
    },
    "owner_object_id": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
    },
    "role": {
      "type": "string",
      "enum": [
        "body",
        "case_arm",
        "condition",
        "init",
        "update",
        "other"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "member_object_ids": {
      "type": "array",
      "items": {
        "$ref": "frog.execution-ir.common.schema.json#/$defs/id_string"
      }
    },
    "attribution": {
      "$ref": "frog.execution-ir.common.schema.json#/$defs/inline_attribution"
    }
  }
}
